{
  "db_name": "PostgreSQL",
  "query": "SELECT x.id, x.title, x.likes, x.views, x.tags\n            FROM article AS x\n                JOIN asset ON asset.id = x.id AND asset.status = 'available' AND asset.deleted_at IS NULL\n            WHERE x.title = $1\n            ORDER BY asset.created_at DESC\n            LIMIT $2 OFFSET $3",
