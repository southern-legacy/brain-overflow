{
  "db_name": "PostgreSQL",
  "query": "SELECT x.id, x.title, x.likes, x.views, x.tags\n            FROM article AS x\n                JOIN asset ON asset.owner = $1 AND asset.status = 'available' AND asset.id = x.id AND asset.deleted_at IS NULL\n            ORDER BY asset.created_at DESC\n            LIMIT $2 OFFSET $3;",
