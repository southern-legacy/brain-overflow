{
  "db_name": "PostgreSQL",
  "query": "SELECT x.id, x.title, x.likes, x.views, x.tags, a.owner as author, a.created_at\n            FROM article AS x JOIN asset AS a\n            ON a.id = x.id AND a.status = 'available' AND a.deleted_at IS NULL\n            WHERE x.title = $1\n            ORDER BY a.created_at DESC\n            LIMIT $2 OFFSET $3",
